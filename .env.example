# RAWG (rawg.io) — commercial-friendly free tier. Sign up at rawg.io/apidocs
# (free, no approval wait). Free tier: 20,000 requests/month, 100k MAU,
# 500k pageviews/month. Requires attribution — see the site footer.
RAWG_API_KEY=

DATABASE_URL="file:./dev.db"

# Affiliate program tracking IDs (no API access needed for these — just
# plain tagged links). Leave blank to hide the "Where to Buy" module.
AMAZON_ASSOCIATE_TAG=
EBAY_CAMPAIGN_ID=

# eBay Browse API (developer.ebay.com) — powers live listing previews on
# game pages. EBAY_ENVIRONMENT is "sandbox" or "production"; sandbox only
# returns fake seeded test data, never real listings. Leave client id/secret
# blank to fall back to the plain search link above.
EBAY_ENVIRONMENT="sandbox"
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
